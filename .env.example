# Supabase frontend connection values
# Copy this file to .env.local and fill values from Supabase Project Settings → API.
# VITE_ variables are public in the browser. Do not store secrets here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key

# Server-side values for Vercel Functions.
# Configure these in Vercel Project Settings → Environment Variables.
# Do not prefix secrets with VITE_.

GEMINI_API_KEY=your-gemini-api-key

# Optional server-side aliases used by /api/generate-report for session checks.
# These may match the public Supabase URL/anon key, but they are read server-side.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-key

# Optional app-level Gemini request limit per signed-in user per organisation.
AI_DAILY_LIMIT_PER_USER=20
