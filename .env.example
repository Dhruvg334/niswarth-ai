# Supabase frontend connection values
# Copy this file to .env.local and fill the values from Supabase Project Settings → API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key

# Server-side AI key for Vercel Function /api/generate-report.
# Do not prefix this with VITE_. Do not expose it in frontend code.
GEMINI_API_KEY=your-gemini-api-key
